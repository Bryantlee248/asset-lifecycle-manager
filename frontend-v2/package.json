    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@types/node": "^20.14.0",
    "@vitejs/plugin-vue": "^5.1.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.0",
    "cross-env": "^7.0.3",
    "happy-dom": "^20.11.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.21",
    "vitest": "^2.1.0",
    "vue-tsc": "^2.0.0"
  }
