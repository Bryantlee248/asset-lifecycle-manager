{
  "name": "asset-lifecycle-manager-frontend-v2",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "UI Modernization V2 (C2 design system) for the IT asset lifecycle manager — batch 1 (command center: dashboard + validation).",
  "scripts": {
    "dev": "vite",
    "build": "cross-env VITE_BASE='/' vite build",
