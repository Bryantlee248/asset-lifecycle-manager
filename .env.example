# ============ IT资产全生命周期管理系统 - 环境变量配置 ============
# 复制此文件为 .env 并修改对应值

# --- JWT密钥（生产环境必须设置） ---
# 优先级: JWT_SECRET_KEY环境变量 > .jwt_secret配置文件 > 报错
# 生成密钥: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=

# --- 运行环境标识 ---
# production: 强制JWT密钥必须存在（否则拒绝启动）
# 不设置或development: 允许自动生成随机密钥（仅开发用）
ENV=production

# --- 管理员默认密码 ---
# 首次启动时创建admin账号的密码（已有账号不会覆盖）
# 生产环境务必修改
DEFAULT_ADMIN_PASSWORD=Admin@2026!Secure

# --- CORS允许来源 ---
# 多来源用逗号分隔，生产环境应限定具体域名
CORS_ORIGINS=http://your-domain.com,http://127.0.0.1:8000

# --- 服务绑定（建议通过start.py参数指定） ---
# HOST=0.0.0.0
# PORT=8000